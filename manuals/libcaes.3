.Dd June 11, 2026
.Dt LIBCAES 3
.Os
.Sh NAME
.Nm libcaes.h
.Nd Library to support cross-platform AES encryption
.Sh SYNOPSIS
.In libcaes.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libcaes_get_version
.Fa "void"
.Fc
.fi
.Pp
Error functions
.nf
.Ft void
.Fo libcaes_error_free
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_error_fprint
.Fa "libcaes_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_error_sprint
.Fa "libcaes_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_error_backtrace_fprint
.Fa "libcaes_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_error_backtrace_sprint
.Fa "libcaes_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.Pp
Context functions
.nf
.Ft int
.Fo libcaes_context_initialize
.Fa "libcaes_context_t **context"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_context_free
.Fa "libcaes_context_t **context"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_context_set_key
.Fa "libcaes_context_t *context"
.Fa "int mode"
.Fa "const uint8_t *key"
.Fa "size_t key_bit_size"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_crypt_cbc
.Fa "libcaes_context_t *context"
.Fa "int mode"
.Fa "const uint8_t *initialization_vector"
.Fa "size_t initialization_vector_size"
.Fa "const uint8_t *input_data"
.Fa "size_t input_data_size"
.Fa "uint8_t *output_data"
.Fa "size_t output_data_size"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_crypt_ccm
.Fa "libcaes_context_t *context"
.Fa "int mode"
.Fa "const uint8_t *nonce"
.Fa "size_t nonce_size"
.Fa "const uint8_t *input_data"
.Fa "size_t input_data_size"
.Fa "uint8_t *output_data"
.Fa "size_t output_data_size"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_crypt_ecb
.Fa "libcaes_context_t *context"
.Fa "int mode"
.Fa "const uint8_t *input_data"
.Fa "size_t input_data_size"
.Fa "uint8_t *output_data"
.Fa "size_t output_data_size"
.Fa "libcaes_error_t **error"
.Fc
.fi
.Pp
Tweaked context functions
.nf
.Ft int
.Fo libcaes_tweaked_context_initialize
.Fa "libcaes_tweaked_context_t **tweaked_context"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_tweaked_context_free
.Fa "libcaes_tweaked_context_t **tweaked_context"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_tweaked_context_set_keys
.Fa "libcaes_tweaked_context_t *tweaked_context"
.Fa "int mode"
.Fa "const uint8_t *key"
.Fa "size_t key_bit_size"
.Fa "const uint8_t *tweak_key"
.Fa "size_t tweak_key_bit_size"
.Fa "libcaes_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcaes_crypt_xts
.Fa "libcaes_tweaked_context_t *tweaked_context"
.Fa "int mode"
.Fa "const uint8_t *tweak_value"
.Fa "size_t tweak_value_size"
.Fa "const uint8_t *input_data"
.Fa "size_t input_data_size"
.Fa "uint8_t *output_data"
.Fa "size_t output_data_size"
.Fa "libcaes_error_t **error"
.Fc
.fi
.Sh DESCRIPTION
The
.Fn libcaes_get_version
function is used to retrieve the library version.
.Sh RETURN VALUES
Most of the functions return NULL or \-1 on error, dependent on the return \
type.
For the actual return values see
.In libcaes.h .
